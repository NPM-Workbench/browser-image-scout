{
  "name": "browser-image-scout",
  "description": "Browser Image Scout is a lightweight TypeScript library for runtime image format support detection in browser environments.",
  "keywords": [
    "avif",
    "gif",
    "jpeg",
    "jpegxl",
    "jxl",
    "jpg",
    "png",
    "svg",
    "webp",
    "browser-image-support",
    "browser-image-compatibility",
    "image-format-support",
    "image-support-detection",
    "check-browser-image-support",
    "detect-browser-image-support",
    "check-browser-avif-support",
    "check-browser-gif-support",
    "check-browser-jpeg-support",
    "check-browser-jpegxl-support",
    "check-browser-jxl-support",
    "check-browser-png-support",
    "check-browser-svg-support",
    "check-browser-webp-support",
    "browser-image-scout",
    "can-i-use-image-format",
    "does-browser-support-image-format",
    "is-image-format-supported-in-browser",
    "how-to-check-browser-image-support",
    "how-to-detect-browser-image-support",
    "how-to-check-if-browser-supports-image-format"
  ],
  "license": "MIT",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
  "dist",
  "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf -v ./dist && rm -rf -v ./coverage",
    "prepublishOnly": "npm run build",
    "test": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js",
    "test:watch": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --watch",
    "test:coverage": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --coverage --verbose"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/NPM-Workbench/browser-image-scout"
  },
  "bugs": {
    "url": "https://github.com/NPM-Workbench/browser-image-scout/issues"
  },
  "homepage": "https://github.com/NPM-Workbench/browser-image-scout"
}
